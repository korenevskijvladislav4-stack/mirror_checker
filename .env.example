PORT=3000

# Google Sheets API (service account, без файла)
# Эти поля возьми из JSON сервисного аккаунта.
GOOGLE_PROJECT_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

GOOGLE_SPREADSHEET_ID=
GOOGLE_SHEET_NAME=

# Диапазон значений. По умолчанию читаем первые 1000 строк и первые 4 колонки (Проект + 3 зеркала).
GOOGLE_SHEETS_VALUES_RANGE=A1:D1000

# Таймаут проверки доступности зеркала
MIRROR_CHECK_TIMEOUT_MS=5000
MIRROR_CHECK_MAX_REDIRECTS=5

# Команда обновления зеркал.
# Должна уметь заменить "target" по проекту, используя "source".
# Пример (PowerShell): MIRROR_REFRESH_COMMAND_TEMPLATE=pwsh -File ./scripts/refresh.ps1 --project {project} --source {source} --target {target}
MIRROR_REFRESH_COMMAND_TEMPLATE=

# Базовая серия для инкремента в случае, если URL не парсится (опционально).
# Обычно не нужно, если домен вида prefix<number>.tld.
MIRROR_URL_REGEX_PREFIX=(?<prefix>[a-zA-Z-]+?)
MIRROR_URL_REGEX_NUMBER=(?<num>\\d+)
MIRROR_URL_REGEX_SUFFIX=(?<suffix>\\.[a-zA-Z0-9.-]+)$

